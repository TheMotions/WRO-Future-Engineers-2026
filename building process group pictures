
# 1. روح للمجلد اللي فيه الصور
cd /path/to/your/photos

# 2. سوّ مجلد جديد
mkdir "building process group pictures"

# 3. حط الصور داخل المجلد
# (اذا الصور في نفس المكان)
mv bc246425-ef26-4a0f-a75f-690d8cfbc486.jpg "building process group pictures/"
mv IMG_4355.jpeg "building process group pictures/"
mv IMG_4351.jpeg "building process group pictures/"

# 4. روح داخل المجلد
cd "building process group pictures"

# 5. ابدأ Git
git init

# 6. ربط الـ repo (غيّر الرابط لرابطك)
git remote add origin https://github.com/USERNAME/REPO-NAME.git

# 7. أضف الصور
git add .

# 8. Commit
git commit -m "Add building process group pictures"

# 9. ارفع على GitHub
git push -u origin main
